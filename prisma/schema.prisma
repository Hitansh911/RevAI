datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id // Firebase UID
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
}

model Business {
  id          String   @id @default(cuid()) // Will use Firebase UID here
  ownerId     String   @unique
  name            String
  category        String
  city            String?
  subCategory     String?
  googleReviewUrl String?
  plan            String   @default("free")
  reviewCount Int      @default(0)
  questions   Json?    // Array of questions generated by AI/User
  reviews        Review[]
  weeklyReports  WeeklyReport[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Review {
  id             String   @id @default(cuid())
  businessId     String
  business       Business @relation(fields: [businessId], references: [id])
  rating         Int
  generatedText  String
  editedText     String?
  overall_rating Int?     // computed avg of category ratings (1-5)
  answers        Json?    // Array of answers corresponding to the questions
  metadata       Json?    // analytics, tracking, voice transcript, review_mode
  postedToGoogle Boolean  @default(false)
  postedAt       DateTime?
  createdAt      DateTime @default(now())
}

// ── Weekly AI Reports ────────────────────────────────────────
model WeeklyReport {
  id                String   @id @default(cuid())
  businessId        String
  business          Business @relation(fields: [businessId], references: [id])

  weekStart         DateTime
  weekEnd           DateTime

  averageRating     Float    @default(0)
  totalReviews      Int      @default(0)

  // Compact aggregate payload:
  // food_rating, service_rating, ambience_rating,
  // positive_count, negative_count, common_complaint,
  // praised_topic, conversion_rate, wow_delta_percent
  structuredMetrics Json?

  // LLM narrative outputs
  aiSummary         String?
  strengths         Json?   // String[]
  improvements      Json?   // String[]
  recommendations   Json?   // String[] (3-5 items)

  pdfUrl            String?
  createdAt         DateTime @default(now())

  @@index([businessId])
  @@index([businessId, weekStart])
}
