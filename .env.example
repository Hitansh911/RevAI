# ─── AI / LLM ──────────────────────────────────────────────────────
# Groq API key — https://console.groq.com/keys
GROQ_API_KEY=gsk_YOUR_GROQ_API_KEY_HERE

# ─── Firebase (client-side) ─────────────────────────────────────────
# Copy from Firebase Console → Project Settings → Your apps → SDK setup
NEXT_PUBLIC_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
NEXT_PUBLIC_FIREBASE_APP_ID=YOUR_FIREBASE_APP_ID

# ─── Firebase Admin (server-side) ──────────────────────────────────
# Copy from Firebase Console → Project Settings → Service accounts → Generate new private key
# IMPORTANT: Paste the entire private key as a single line with literal \n characters
# (not actual newlines). Example format:
#   FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT_HERE\n-----END PRIVATE KEY-----\n"

# ─── Google Business Profile API ───────────────────────────────────
# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Scopes needed: https://www.googleapis.com/auth/business.manage
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-YOUR_GOOGLE_CLIENT_SECRET
# Production: set this to https://your-app.vercel.app/api/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ─── App ────────────────────────────────────────────────────────────
# Production: set this to your Vercel deployment URL (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Hugging Face (voice sentiment analysis) ────────────────────────
# Get your key at https://huggingface.co/settings/tokens
HF_API_KEY=hf_YOUR_HUGGINGFACE_TOKEN_HERE

# ─── PostgreSQL / Neon Database ─────────────────────────────────────
# Get from Neon Console → your project → Connection string
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── Clerk Authentication ────────────────────────────────────────────
# From Clerk Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_CLERK_PUBLISHABLE_KEY
CLERK_SECRET_KEY=sk_test_YOUR_CLERK_SECRET_KEY

# ─── Resend (email dispatcher for weekly reports) ───────────────────
# Get your key at https://resend.com/api-keys
RESEND_API_KEY=re_YOUR_RESEND_API_KEY

# Sender address — use onboarding@resend.dev for testing,
# or a verified custom domain address for production
RESEND_FROM_EMAIL=onboarding@resend.dev

# ─── Cron Job Security ──────────────────────────────────────────────
# Random secret string to protect /api/cron/weekly-reports
# Generate one with: openssl rand -hex 32
# Vercel sends this automatically as: Authorization: Bearer <secret>
CRON_SECRET=your-random-secret-string-here
